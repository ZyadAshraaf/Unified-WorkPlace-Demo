# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000                        # Main app port (browser access)
TEAMS_PORT=3001                  # Teams tunnel port

# ─── Security ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-in-production   # Must be a long random string in production

# ─── AI / External Services ───────────────────────────────────────────────────
GROQ_API_KEY=                    # Required for HR Chat and Leave Assistant (Groq API key)
DOCEVAL_URL=doceval-8362469192e8.herokuapp.com   # Doc/proposal/resume AI upstream host

# ─── Microsoft Teams Integration ──────────────────────────────────────────────
TEAMS_APP_ID=                    # Teams app ID from the manifest (teams-app/manifest.json)
MAIN_APP_ORIGIN=http://localhost:3000   # URL of the main app — used by the Teams proxy server
